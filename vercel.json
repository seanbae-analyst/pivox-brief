{
  "builds": [
    { "src": "api/research.py", "use": "@vercel/python", "config": { "includeFiles": ["engine/**", "data/dart_corp_listed.json"] } },
    { "src": "docs/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/research", "dest": "/api/research.py" },
    { "src": "/", "dest": "/docs/pack.html" },
    { "src": "/(.*)", "dest": "/docs/$1" }
  ]
}
