# Copy to .env and fill in. .env is gitignored.

# SEC EDGAR (US research pack, engine/edgar.py) — keyless, but SEC's fair-access
# policy asks you to declare an identity. Set this to your name + email; it is sent
# as the User-Agent on every request. Without it, requests fall back to a generic
# UA and may be throttled/blocked. See DATA_SOURCES.md.
EDGAR_USER_AGENT=

# Open DART (KR research pack, engine/dart.py) — free key required. Register at
# https://opendart.fss.or.kr → set the issued key here before the Korean path.
DART_API_KEY=

# Anthropic Claude API — required for extraction (engine/extract.py)
ANTHROPIC_API_KEY=

# Financial Modeling Prep — required only to fetch transcripts live (engine/fetch.py).
# Phase 1 can run from a local file in data/transcripts/ without this.
FMP_API_KEY=

# Supabase — backs the public settings picker (docs/settings.html) so the homepage can
# save your theme/level selection and the morning cron reads it. Free tier. The ANON key
# is public by design (baked into the static page). Without these, the brief uses the local
# watchlist.json / DEFAULT instead. Setup: create a free project → run the SQL in docs (or
# README) → paste the Project URL + anon public key here.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_KEY=          # (legacy/service key — not required for the picker)

# FRED (St. Louis Fed) — free key. Powers the market macro band + near-real-time daily
# flow in the morning brief (engine/market.py). Without it the daily tape is omitted.
FRED_API_KEY=

# Finnhub — free key. Sell-side recommendation consensus per stock (engine/analysts.py).
# Free tier omits price targets; they render automatically on a paid key.
FINNHUB_API_KEY=

# Morning brief email delivery (engine/notify.py) — OPTIONAL, provider cascade.
# scripts/brief.py --send mails the digest; --check mails on big-event alerts only.
# Needs BRIEF_TO + at least one provider. Tries SendGrid first, then Gmail SMTP.
BRIEF_TO=             # recipient(s), comma-separated, e.g. you@gmail.com
#   Provider A — SendGrid (HTTPS). BRIEF_FROM must be a verified SendGrid sender.
SENDGRID_API_KEY=
BRIEF_FROM=noreply@pivoxquant.com
#   Provider B — Gmail SMTP ($0, no quota wall). Generate a 16-char App Password at
#   myaccount.google.com → Security → 2-Step Verification → App passwords (needs 2FA on).
GMAIL_USER=           # your.address@gmail.com (also the sender)
GMAIL_APP_PASSWORD=   # the 16-char app password (spaces ok)
