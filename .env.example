# Copy to .env and fill in. .env is gitignored.

# SEC EDGAR (US research pack, engine/edgar.py) — keyless, but SEC's fair-access
# policy asks you to declare an identity. Set this to your name + email; it is sent
# as the User-Agent on every request. Without it, requests fall back to a generic
# UA and may be throttled/blocked. See DATA_SOURCES.md.
EDGAR_USER_AGENT=

# Open DART (KR research pack, engine/dart.py) — free key required. Register at
# https://opendart.fss.or.kr → set the issued key here before the Korean path.
DART_API_KEY=

# Anthropic Claude API — required for extraction (engine/extract.py)
ANTHROPIC_API_KEY=

# Financial Modeling Prep — required only to fetch transcripts live (engine/fetch.py).
# Phase 1 can run from a local file in data/transcripts/ without this.
FMP_API_KEY=

# Supabase — used from Phase 4 (storage). Not needed for Phase 1.
SUPABASE_URL=
SUPABASE_KEY=

# FRED (St. Louis Fed) — free key. Powers the market macro band + near-real-time daily
# flow in the morning brief (engine/market.py). Without it the daily tape is omitted.
FRED_API_KEY=

# Finnhub — free key. Sell-side recommendation consensus per stock (engine/analysts.py).
# Free tier omits price targets; they render automatically on a paid key.
FINNHUB_API_KEY=

# Morning brief email delivery (engine/notify.py) — OPTIONAL. Inert unless both are set.
# scripts/brief.py --send mails the digest; the big-event trigger can mail on alerts only.
SENDGRID_API_KEY=
BRIEF_TO=             # recipient(s), comma-separated, e.g. you@gmail.com
BRIEF_FROM=noreply@pivoxquant.com
